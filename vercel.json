{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "policestationrepuk.com" }],
      "destination": "https://policestationrepuk.org/$1",
      "statusCode": 301
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.policestationrepuk.com" }],
      "destination": "https://policestationrepuk.org/$1",
      "statusCode": 301
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.policestationrepuk.org" }],
      "destination": "https://policestationrepuk.org/$1",
      "statusCode": 301
    }
  ],
  "crons": [
    {
      "path": "/api/cron/reverification-sweep",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/sync-dscc-register",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/regulatory-verify",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/indexnow",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/cron/custody-number-discovery",
      "schedule": "0 */6 * * *"
    }
  ]
}
