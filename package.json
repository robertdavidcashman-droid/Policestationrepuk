{
  "name": "policestationrepuk",
  "version": "1.0.0",
  "private": true,
  "browserslist": {
    "production": [
      "chrome >= 93",
      "edge >= 93",
      "firefox >= 92",
      "safari >= 15.4",
      "ios_saf >= 15.4",
      "not dead"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/blog/fetch-hero-images.mjs",
    "build": "next build",
    "postbuild": "npx tsx scripts/postbuild-indexnow.ts",
    "start": "next start",
    "lint": "next lint",
    "deploy:vercel": "npx vercel deploy --prod --yes",
    "qa:smoke": "node scripts/qa-smoke.mjs",
    "qa:lighthouse": "lhci autorun",
    "crawl": "npx playwright install chromium && node scripts/crawl-site.js",
    "crawl:ts": "npx playwright install chromium && npx tsx scripts/crawl-site.ts",
    "crawl:batched": "npx playwright install chromium && npx tsx scripts/crawl-batched.ts",
    "classify": "npx tsx scripts/classify-pages.ts",
    "transform-data": "npx tsx scripts/transform-to-directory-data.ts",
    "generate-seo": "node scripts/generate-static-seo.js",
    "scrape": "node scripts/scraper.js",
    "scrape:org": "node scripts/scraper.js --url https://policestationrepuk.org",
    "api": "node scripts/server.js",
    "api:dev": "PORT=4000 node scripts/server.js",
    "pipeline": "node scripts/scraper.js && node scripts/server.js",
    "parity": "npx tsx scripts/parity-verify.ts",
    "visual-parity": "npx playwright install chromium && npx tsx scripts/visual-parity.ts",
    "parity:full": "npx tsx scripts/final-parity-suite.ts",
    "audit:links": "node scripts/audit/internal-link-audit.mjs",
    "audit:crawl": "node scripts/audit/sitemap-crawl.mjs",
    "audit:full": "node scripts/audit/full-site-audit.mjs",
    "audit:seo": "node scripts/audit/seo-audit.mjs --concurrency 8",
    "audit:blog-seo": "npx tsx scripts/audit/blog-seo.ts",
    "audit:blog-orphans": "npx tsx scripts/audit/blog-orphan-links.ts",
    "audit:content-accuracy": "npx tsx scripts/audit/content-accuracy-scan.ts",
    "validate:schema": "npx tsx scripts/audit/validate-blog-schema.ts",
    "test:directory-search": "npx tsx scripts/directory-search-selftest.ts",
    "blog:heroes": "node scripts/blog/build-blog-hero-webp.mjs",
    "blog:heroes:fetch": "node scripts/blog/fetch-hero-images.mjs",
    "social:preview": "node scripts/generate-social-preview.mjs",
    "test": "vitest run",
    "custody:discover": "npx tsx scripts/run-custody-discovery.ts",
    "custody:setup": "node scripts/setup-custody-discovery.mjs",
    "custody:seed": "npx tsx scripts/seed-custody-discovery.ts",
    "custody:review": "echo 'Open /admin/custody-number-review after signing in as admin'",
    "psa:coverage": "npx tsx scripts/build-psa-coverage.ts",
    "buffer:schedule": "npx tsx scripts/run-buffer-blog-scheduler.ts",
    "buffer:list-today": "npx tsx scripts/list-buffer-posts-today.ts",
    "buffer:supplement-today": "npx tsx scripts/run-buffer-supplement-today.ts",
    "buffer:replace-today": "npx tsx scripts/replace-buffer-schedule-today.ts",
    "buffer:verify-feeds": "npx tsx scripts/verify-buffer-feeds.ts",
    "buffer:probe-images": "npx tsx scripts/probe-feed-images.ts",
    "buffer:schedule-gaps": "npx tsx scripts/schedule-buffer-gap-posts.ts",
    "buffer:verify-scheduled-images": "npx tsx scripts/verify-buffer-scheduled-images.ts",
    "buffer:verify-scheduled-gbp": "npx tsx scripts/verify-buffer-scheduled-images.ts --google-business",
    "buffer:repair-gbp": "npx tsx scripts/repair-buffer-gbp-images.ts",
    "buffer:smoke": "npx tsx scripts/smoke-buffer-api.ts",
    "test:buffer:ci": "vitest run __tests__/buffer-config.test.ts __tests__/buffer-client.test.ts __tests__/buffer-blog-scheduler.test.ts __tests__/buffer-day-night.test.ts __tests__/buffer-rss.test.ts __tests__/buffer-rss-fetch.test.ts __tests__/buffer-feeds.test.ts __tests__/buffer-feed-health.test.ts __tests__/buffer-image-url.test.ts __tests__/buffer-psrtrain-feed.test.ts __tests__/buffer-scheduler-integration.test.ts __tests__/buffer-scheduler-gbp-preflight-integration.test.ts __tests__/buffer-cron-route.test.ts __tests__/buffer-blog-catalog.test.ts __tests__/buffer-blog-hero-jpeg.test.ts __tests__/buffer-gbp-preflight.test.ts __tests__/buffer-gbp-feed-fallbacks.test.ts __tests__/buffer-email.test.ts __tests__/cron-auth.test.ts && npx tsx scripts/probe-feed-images.ts --google-business",
    "test:buffer": "npm run test:buffer:ci && npm run buffer:verify-feeds",
    "test:assistant": "vitest run __tests__/assistant-match.test.ts __tests__/assistant-cover-routing.test.ts __tests__/assistant-kent-promo.test.ts __tests__/assistant-llm.test.ts __tests__/assistant-query-route.test.ts __tests__/assistant-content-accuracy.test.ts __tests__/assistant-guardrails-extended.test.ts __tests__/assistant-output-validator.test.ts __tests__/assistant-eval.test.ts __tests__/assistant-logging.test.ts",
    "test:assistant:e2e": "npx playwright install chromium && playwright test --config=playwright.assistant.config.ts",
    "verify": "npm run lint && npx tsc --noEmit && npm test && npm run test:assistant && npm run test:directory-search && npm run validate:schema && npm run audit:blog-seo",
    "law-firms:clean": "node scripts/clean-law-firms.mjs",
    "test:ls:verify-checkout": "node scripts/verify-test-checkout.mjs",
    "smoke:ls": "node scripts/smoke-lemonsqueezy.mjs",
    "analyze": "ANALYZE=true next build",
    "audit:validate": "node scripts/audit-validate.mjs",
    "audit:validate:fix": "node scripts/audit-validate.mjs --fix",
    "validate:articles": "npx tsx scripts/validate-articles.ts",
    "validate:articles:fix": "npx tsx scripts/validate-articles.ts --fix",
    "audit:site": "node scripts/audit/site-audit-run.mjs",
    "audit:site:report": "node scripts/audit/site-audit-report.mjs",
    "test:audit": "playwright test --config=playwright.audit.config.ts",
    "test:audit:articles": "playwright test --config=playwright.audit.config.ts tests/audit/how-to-become.spec.ts tests/audit/article-rendering.spec.ts",
    "test:audit:links": "playwright test --config=playwright.audit.config.ts tests/audit/link-audit.spec.ts tests/audit/nav-footer.spec.ts",
    "test:audit:a11y": "playwright test --config=playwright.audit.config.ts tests/audit/a11y.spec.ts",
    "test:audit:seo": "playwright test --config=playwright.audit.config.ts tests/audit/seo.spec.ts",
    "test:audit:responsive": "playwright test --config=playwright.audit.config.ts tests/audit/responsive.spec.ts",
    "test:audit:console": "playwright test --config=playwright.audit.config.ts tests/audit/console-errors.spec.ts",
    "indexnow": "npx tsx scripts/submit-indexnow.ts",
    "laa:fetch": "npx tsx scripts/fetch-laa-crime-providers.ts",
    "laa:seed": "npx tsx scripts/seed-laa-crime-providers.ts",
    "laa:audit": "npx tsx scripts/audit-legal-directory.ts",
    "laa:clean": "npx tsx scripts/clean-legal-directory-duplicates.ts",
    "audit:station-phones": "npx tsx scripts/verify-station-phone-accuracy.ts",
    "audit:station-phones:fix": "npx tsx scripts/restore-cleared-station-phones.ts --write && npx tsx scripts/correct-station-phones.ts --write && npx tsx scripts/verify-station-phone-accuracy.ts --write",
    "laa:refresh": "npm run laa:fetch && npm run laa:seed"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "@upstash/redis": "^1.37.0",
    "@vercel/blob": "^2.4.0",
    "leaflet": "^1.9.4",
    "marked": "^17.0.4",
    "next": "^15.2.3",
    "openai": "^4.104.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@base44/sdk": "^0.8.22",
    "@eslint/eslintrc": "^3.3.5",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.0.14",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.13.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.3",
    "express": "^5.2.1",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.2",
    "xlsx": "^0.18.5"
  }
}
