# Site
NEXT_PUBLIC_SITE_URL=https://policestationrepuk.org
APP_BASE_URL=https://policestationrepuk.org

# Upstash Redis (sessions, station overrides, custody discovery)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin
ADMIN_EMAILS=you@example.com
ADMIN_PASSWORD=
ADMIN_DECISION_TOKEN_SECRET=

# Cron (Vercel scheduled jobs)
CRON_SECRET=

# Custody number discovery
SERPER_API_KEY=
OPENAI_API_KEY=
CUSTODY_DISCOVERY_BATCH_LIMIT=25
CUSTODY_DISCOVERY_CACHE_SECONDS=300
CUSTODY_DISCOVERY_NOTIFY_EMAIL=robertdavidcashman@gmail.com

# Buffer (social scheduling — https://buffer.com/developers/api)
BUFFER_API_KEY=
BUFFER_ORGANIZATION_ID=
BUFFER_CHANNEL_TWITTER_ID=
BUFFER_CHANNEL_LINKEDIN_ID=
BUFFER_CHANNEL_GOOGLEBUSINESS_ID=
# Per content feed: 5 posts/day (3 day + 2 night) from each feed in BUFFER_CONTENT_FEEDS
BUFFER_SCHEDULER_POSTS_PER_FEED=5
BUFFER_SCHEDULER_DAY_POSTS=3
BUFFER_SCHEDULER_NIGHT_POSTS=2
BUFFER_SCHEDULER_COOLDOWN_DAYS=14
BUFFER_SCHEDULER_TIMEZONE=Europe/London
BUFFER_SCHEDULER_DAY_START_HOUR=8
BUFFER_SCHEDULER_DAY_END_HOUR=21
BUFFER_SCHEDULER_NIGHT_START_HOUR=21
BUFFER_SCHEDULER_NIGHT_END_HOUR=23
BUFFER_SCHEDULER_EARLY_START_HOUR=0
BUFFER_SCHEDULER_EARLY_END_HOUR=7
BUFFER_SCHEDULER_MIN_GAP_MINUTES=90
BUFFER_SCHEDULER_NIGHT_MIN_GAP_MINUTES=60
# Optional JSON override — default scheduler posts ALL four feeds:
#   policestationrepuk (local) + custodynote + policestationagent + psrtrain (RSS).
#
# CROSS-SITE RECONCILIATION (four-site SEO plan, Phase 3): once psrtrain.com and
# custodynote.com run their OWN Buffer schedulers (app/api/buffer/schedule), and
# policestationagent.com keeps its GitHub Actions scheduler, set this override so
# REPUK only schedules its own feed and never double-posts the others:
#   BUFFER_CONTENT_FEEDS=[{"id":"policestationrepuk","type":"local"}]
# (validateContentFeeds() will log a missing-IDs warning — expected, not an error.)
#
# Example partial override (REPUK + PSA only):
# BUFFER_CONTENT_FEEDS=[{"id":"policestationrepuk","type":"local"},{"id":"policestationagent","type":"rss","url":"https://www.policestationagent.com/api/blog/rss-proxy"}]
BUFFER_SCHEDULER_NOTIFY_EMAIL=robertdavidcashman@gmail.com

# Optional Supabase (form submissions only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
