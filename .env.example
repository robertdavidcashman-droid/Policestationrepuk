# RepUK environment variable names (safe template — no secret values).
# Copy to `.env.local` for development. Production/preview values live in Vercel.

# --- Core site ---
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
CRON_SECRET=local-dev-placeholder-not-for-production

# --- KV / Upstash (required for registrations, outreach, custody) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Legacy aliases also supported:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Email (Resend) ---
RESEND_API_KEY=
# Preview deployments enforce allowlist: robertdavidcashman@gmail.com only
PREVIEW_EMAIL_ALLOWLIST=

# --- Outreach automation ---
FIRM_OUTREACH_ENABLED=false
FIRM_OUTREACH_DRY_RUN=1
FIRM_OUTREACH_WEBHOOK_SECRET=
DECISION_TOKEN_SECRET=

# --- Buffer scheduler ---
BUFFER_API_KEY=
BUFFER_ORGANIZATION_ID=
BUFFER_CHANNEL_TWITTER_ID=
BUFFER_CHANNEL_LINKEDIN_ID=
BUFFER_CHANNEL_GOOGLEBUSINESS_ID=
# Prefer local-only once siblings self-schedule (avoids double-posting):
# BUFFER_CONTENT_FEEDS=[{"id":"policestationrepuk","type":"local"}]
BUFFER_SCHEDULER_TIMEZONE=Europe/London
BUFFER_SCHEDULER_NOTIFY_EMAIL=

# --- Automation health-check / self-healing (Upstash KV backed) ---
# Safe defaults for first production rollout: dry-run on, auto-repair off.
AUTOMATION_ENABLED=true
AUTOMATION_DRY_RUN=1
AUTOMATION_TIMEZONE=Europe/London
AUTOMATION_ALLOW_NON_PROD=0
DAILY_HEALTHCHECK_ENABLED=true
DAILY_HEALTHCHECK_HOUR=7
WATCHDOG_ENABLED=true
BUFFER_HEALTHCHECK_ENABLED=true
CROSS_SITE_HEALTHCHECK_ENABLED=true
AUTO_REPAIR_ENABLED=0
AUTO_RETRY_ENABLED=1
MAX_RETRY_COUNT=3
STUCK_JOB_TIMEOUT_MINUTES=120
LOCK_TIMEOUT_MINUTES=30
ALERT_REMINDER_HOURS=24
DAILY_SUCCESS_EMAIL_ENABLED=true
AUTOMATION_ALERT_EMAIL=
# Sibling remote gap-fill over HTTPS (off by default — siblings self-schedule)
CROSS_SITE_REMOTE_REPAIR_ENABLED=0

# --- Custody discovery ---
SERPER_API_KEY=
CUSTODY_DISCOVERY_BATCH_LIMIT=10
CUSTODY_DISCOVERY_MAX_ELAPSED_MS=240000

# --- Supabase (optional local mirror / preview project) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Analytics (Vercel only in production layout) ---
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
